{
    "openapi": "3.0.0",
    "info": {
        "title": "My API",
        "version": "1.0.0",
        "description": "API documentation for my application"
    },
    "servers": [
        {
            "url": "http://localhost:6050",
            "description": "Local server"
        }
    ],
    "paths": {
        "/auth/login": {
            "post": {
                "summary": "User login",
                "description": "Realiza o login",
                "tags": [
                    "Authentication"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "user_email": {
                                        "type": "string",
                                        "description": "email do usuario",
                                        "example": "email@email"
                                    },
                                    "user_password": {
                                        "type": "string",
                                        "description": "senha do usuario",
                                        "example": "password123"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful login"
                    },
                    "400": {
                        "description": "Invalid request body"
                    },
                    "401": {
                        "description": "Invalid credentials"
                    },
                    "404": {
                        "description": "User not found"
                    },
                    "500": {
                        "description": "Internal server error"
                    },
                    "responseHeader": {
                        "set-cookie": {
                            "description": "JWT token set in cookie",
                            "schema": {
                                "type": "string",
                                "example": ""
                            }
                        }
                    }
                }
            }
        },
        "/auth/refresh": {
            "post": {
                "summary": "User login",
                "description": "Realiza o login",
                "tags": [
                    "Authentication"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "user_email": {
                                        "type": "string",
                                        "description": "email do usuario",
                                        "example": "email@email"
                                    },
                                    "user_password": {
                                        "type": "string",
                                        "description": "senha do usuario",
                                        "example": "password123"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful login"
                    },
                    "400": {
                        "description": "Invalid request body"
                    },
                    "401": {
                        "description": "Invalid credentials"
                    },
                    "404": {
                        "description": "User not found"
                    },
                    "500": {
                        "description": "Internal server error"
                    },
                    "responseHeader": {
                        "set-cookie": {
                            "description": "JWT token set in cookie",
                            "schema": {
                                "type": "string",
                                "example": ""
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {},
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    }
}